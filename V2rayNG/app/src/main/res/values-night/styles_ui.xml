<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.V2Ray.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/color_card_outline</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.V2Ray.Card.Section" parent="Widget.V2Ray.Card.Primary">
        <item name="cardBackgroundColor">@color/color_settings_section_surface</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.V2Ray.Card.Subtle" parent="Widget.V2Ray.Card">
        <item name="cardBackgroundColor">@color/color_settings_row_surface</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.V2Ray.Card.ListItem" parent="Widget.V2Ray.Card.TabGroup">
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.V2Ray.Card.HomeList" parent="Widget.V2Ray.Card.ListItem">
        <item name="cardCornerRadius">18dp</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardElevation">3dp</item>
    </style>

    <style name="Widget.V2Ray.Card.HomeDock" parent="Widget.V2Ray.Card.Primary">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardBackgroundColor">@color/color_home_card_bg_dock</item>
        <item name="strokeColor">@android:color/transparent</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardElevation">4dp</item>
    </style>
</resources>
