<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Night theme: inherit the shared AppThemeBase and only override night-specific items -->
    <style name="AppThemeDayNight" parent="AppThemeBase">
        <!-- Night mode specific overrides -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>

    <style name="AppThemeDayNight.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_launcher</item>
        <item name="windowSplashScreenBackground">@color/md_theme_background</item>
        <item name="windowSplashScreenAnimationDuration">220</item>
        <item name="postSplashScreenTheme">@style/AppThemeDayNight.NoActionBar</item>
    </style>

</resources>
