<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/motion_enter_emphasized"
    android:shareInterpolator="true">
    <translate
        android:duration="220"
        android:fromYDelta="3.5%p"
        android:toYDelta="0%p" />
    <alpha
        android:duration="220"
        android:fromAlpha="0"
        android:toAlpha="1" />
    <scale
        android:duration="220"
        android:fromXScale="0.992"
        android:fromYScale="0.992"
        android:pivotX="50%"
        android:pivotY="50%"
        android:toXScale="1"
        android:toYScale="1" />
</set>
