<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@interpolator/motion_enter_emphasized"
    android:shareInterpolator="true">
    <alpha
        android:duration="180"
        android:fromAlpha="0.95"
        android:toAlpha="1" />
    <scale
        android:duration="180"
        android:fromXScale="0.996"
        android:fromYScale="0.996"
        android:pivotX="50%"
        android:pivotY="50%"
        android:toXScale="1"
        android:toYScale="1" />
</set>
