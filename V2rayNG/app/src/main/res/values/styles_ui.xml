<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.V2Ray.Eyebrow" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.V2Ray.ScreenTitle" parent="TextAppearance.AppCompat.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.V2Ray.CardTitle" parent="TextAppearance.AppCompat.Subhead">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">0dp</item>
    </style>

    <style name="TextAppearance.V2Ray.BodyStrong" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.V2Ray.Body" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.V2Ray.Support" parent="TextAppearance.AppCompat.Small">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.V2Ray.Badge" parent="TextAppearance.AppCompat.Small">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="TextAppearance.V2Ray.Tab" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.V2Ray.TabLarge" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.V2Ray.FormLabel" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
    </style>

    <style name="TextAppearance.V2Ray.MenuItem" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
    </style>

    <style name="Widget.V2Ray.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/md_theme_outlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.V2Ray.Card.Primary" parent="Widget.V2Ray.Card">
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
    </style>

    <style name="Widget.V2Ray.Card.Section" parent="Widget.V2Ray.Card.Primary">
        <item name="cardCornerRadius">@dimen/shape_corner_dp20</item>
    </style>

    <style name="Widget.V2Ray.Card.Subtle" parent="Widget.V2Ray.Card">
        <item name="cardBackgroundColor">@color/md_theme_surfaceVariant</item>
        <item name="cardCornerRadius">22dp</item>
    </style>

    <style name="Widget.V2Ray.Card.TabGroup" parent="Widget.V2Ray.Card.Subtle">
        <item name="cardCornerRadius">@dimen/shape_corner_dp16</item>
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
    </style>

    <style name="Widget.V2Ray.Card.TopTabs" parent="Widget.V2Ray.Card.Primary">
        <item name="cardCornerRadius">19dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
        <item name="cardBackgroundColor">@color/md_theme_surfaceVariant</item>
    </style>

    <style name="Widget.V2Ray.Card.ListItem" parent="Widget.V2Ray.Card.TabGroup">
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
        <item name="cardCornerRadius">20dp</item>
    </style>

    <style name="Widget.V2Ray.Card.HomeConnection" parent="Widget.V2Ray.Card.Primary">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardBackgroundColor">@android:color/transparent</item>
        <item name="strokeColor">@android:color/transparent</item>
    </style>

    <style name="Widget.V2Ray.Button.HomePrimary" parent="Widget.V2Ray.Button.Primary">
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">@dimen/view_height_dp44</item>
    </style>

    <style name="Widget.V2Ray.Button.HomeSecondary" parent="Widget.V2Ray.Button.Secondary">
        <item name="cornerRadius">16dp</item>
        <item name="android:minHeight">@dimen/view_height_dp44</item>
    </style>

    <style name="Widget.V2Ray.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/view_height_dp56</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="iconPadding">@dimen/padding_spacing_dp8</item>
        <item name="iconGravity">textStart</item>
        <item name="cornerRadius">20dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.V2Ray.Button.Primary" parent="Widget.V2Ray.Button">
        <item name="backgroundTint">@color/md_theme_surface</item>
        <item name="strokeColor">@color/md_theme_outlineVariant</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
        <item name="iconTint">@color/md_theme_onSurface</item>
    </style>

    <style name="Widget.V2Ray.Button.Secondary" parent="Widget.V2Ray.Button">
        <item name="backgroundTint">@color/md_theme_surfaceVariant</item>
        <item name="strokeColor">@color/md_theme_outlineVariant</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
        <item name="iconTint">@color/md_theme_onSurfaceVariant</item>
    </style>

    <style name="Widget.V2Ray.Toolbar" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:background">@color/md_theme_background</item>
        <item name="titleTextColor">@color/md_theme_onBackground</item>
        <item name="subtitleTextColor">@color/md_theme_onSurfaceVariant</item>
        <item name="popupTheme">@style/ThemeOverlay.V2Ray.PopupMenu</item>
    </style>

    <style name="Widget.V2Ray.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/bg_form_field</item>
        <item name="android:paddingStart">@dimen/padding_spacing_dp14</item>
        <item name="android:paddingTop">@dimen/padding_spacing_dp12</item>
        <item name="android:paddingEnd">@dimen/padding_spacing_dp14</item>
        <item name="android:paddingBottom">@dimen/padding_spacing_dp12</item>
        <item name="android:minHeight">@dimen/view_height_dp56</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
        <item name="android:textColorHint">@color/md_theme_onSurfaceVariant</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Widget.V2Ray.Spinner" parent="Widget.AppCompat.Spinner">
        <item name="android:background">@drawable/bg_form_field</item>
        <item name="android:minHeight">@dimen/view_height_dp56</item>
        <item name="android:paddingStart">@dimen/padding_spacing_dp12</item>
        <item name="android:paddingEnd">@dimen/padding_spacing_dp12</item>
        <item name="android:popupBackground">@drawable/bg_popup_surface</item>
        <item name="android:dropDownSelector">@drawable/bg_selected_indicator</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="Widget.V2Ray.PopupMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/bg_menu_surface</item>
        <item name="overlapAnchor">false</item>
    </style>

    <style name="Widget.V2Ray.BottomSheet" parent="Widget.Material3.BottomSheet.Modal">
        <item name="android:background">@drawable/bg_popup_surface</item>
        <item name="backgroundTint">@color/md_theme_surface</item>
    </style>

    <style name="ThemeOverlay.V2Ray.PopupMenu" parent="ThemeOverlay.Material3.Light">
        <item name="android:textColorPrimary">@color/md_theme_onSurface</item>
        <item name="android:textColorSecondary">@color/md_theme_onSurfaceVariant</item>
        <item name="android:popupBackground">@drawable/bg_menu_surface</item>
        <item name="popupMenuStyle">@style/Widget.V2Ray.PopupMenu</item>
    </style>

    <style name="ThemeOverlay.V2Ray.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.V2Ray.BottomSheet</item>
    </style>

</resources>
