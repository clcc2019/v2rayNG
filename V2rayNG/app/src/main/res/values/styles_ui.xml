<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.V2Ray.Eyebrow" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="TextAppearance.V2Ray.ScreenTitle" parent="TextAppearance.AppCompat.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.V2Ray.CardTitle" parent="TextAppearance.AppCompat.Subhead">
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineSpacingExtra">1dp</item>
    </style>

    <style name="TextAppearance.V2Ray.BodyStrong" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.V2Ray.Body" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textSize">14sp</item>
    </style>

    <style name="TextAppearance.V2Ray.Support" parent="TextAppearance.AppCompat.Small">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="TextAppearance.V2Ray.Badge" parent="TextAppearance.AppCompat.Small">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.V2Ray.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/md_theme_outlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.V2Ray.Card.Primary" parent="Widget.V2Ray.Card">
        <item name="cardBackgroundColor">@color/md_theme_surface</item>
    </style>

    <style name="Widget.V2Ray.Card.Subtle" parent="Widget.V2Ray.Card">
        <item name="cardBackgroundColor">@color/md_theme_surfaceVariant</item>
        <item name="cardCornerRadius">22dp</item>
    </style>

    <style name="Widget.V2Ray.Button" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">@dimen/view_height_dp56</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="iconPadding">@dimen/padding_spacing_dp8</item>
        <item name="iconGravity">textStart</item>
        <item name="cornerRadius">20dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.V2Ray.Button.Primary" parent="Widget.V2Ray.Button">
        <item name="backgroundTint">@color/md_theme_surface</item>
        <item name="strokeColor">@color/md_theme_outlineVariant</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
        <item name="iconTint">@color/md_theme_onSurface</item>
    </style>

    <style name="Widget.V2Ray.Button.Secondary" parent="Widget.V2Ray.Button">
        <item name="backgroundTint">@color/md_theme_surfaceVariant</item>
        <item name="strokeColor">@color/md_theme_outlineVariant</item>
        <item name="android:textColor">@color/md_theme_onSurface</item>
        <item name="iconTint">@color/md_theme_onSurfaceVariant</item>
    </style>

</resources>
