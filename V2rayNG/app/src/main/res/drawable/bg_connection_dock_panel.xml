<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_dock_surface_top"
                android:centerColor="@color/color_connection_dock_surface_mid"
                android:endColor="@color/color_connection_dock_surface_bottom" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_dock_highlight_top"
                android:centerColor="@color/color_connection_dock_highlight_mid"
                android:endColor="@color/color_connection_dock_highlight_bottom" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="10dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_dock_depth_top"
                android:endColor="@color/color_connection_dock_depth_bottom" />
        </shape>
    </item>

    <item
        android:left="0.5dp"
        android:top="0.5dp"
        android:right="0.5dp"
        android:bottom="0.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="16.5dp" />
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="0.75dp"
                android:color="@color/color_connection_dock_glass_stroke" />
        </shape>
    </item>

</layer-list>
