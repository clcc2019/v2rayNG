<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:width="46dp"
        android:height="46dp"
        android:gravity="center">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/color_home_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/color_home_card_stroke" />
        </shape>
    </item>

    <item
        android:width="46dp"
        android:height="46dp"
        android:gravity="center"
        android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#5CFFFFFF" />
        </shape>
    </item>

    <item
        android:width="30dp"
        android:height="30dp"
        android:gravity="center"
        android:drawable="@drawable/ic_launcher_mark" />
</layer-list>
