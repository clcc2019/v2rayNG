<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/color_home_surface_selected" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/color_home_card_stroke_selected" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item
                android:height="20dp"
                android:gravity="top">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#42FFFFFF"
                        android:centerColor="#18FFFFFF"
                        android:endColor="#00FFFFFF" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <item
                android:height="20dp"
                android:gravity="top">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="90"
                        android:startColor="#42FFFFFF"
                        android:centerColor="#18FFFFFF"
                        android:endColor="#00FFFFFF" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
