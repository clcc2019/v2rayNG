<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/color_home_glass_highlight_strong"
                android:centerColor="@color/color_home_glass_highlight_soft"
                android:endColor="@android:color/transparent" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item
        android:gravity="top|end"
        android:height="104dp"
        android:width="120dp">
        <shape android:shape="oval">
            <gradient
                android:centerColor="@color/color_home_glass_orb_highlight"
                android:endColor="@android:color/transparent"
                android:gradientRadius="64dp"
                android:type="radial" />
        </shape>
    </item>

</layer-list>
