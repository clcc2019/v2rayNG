<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#FBFDFF"
                android:startColor="@color/md_theme_background" />
        </shape>
    </item>
    <item android:top="-120dp" android:right="-120dp">
        <shape android:shape="oval">
            <solid android:color="#14B6D8FA" />
        </shape>
    </item>
    <item android:left="-140dp" android:bottom="-180dp">
        <shape android:shape="oval">
            <solid android:color="#12DDF5E7" />
        </shape>
    </item>
</layer-list>
