            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_dock_button_surface"
                android:endColor="@color/color_home_surface_soft" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="18dp">
