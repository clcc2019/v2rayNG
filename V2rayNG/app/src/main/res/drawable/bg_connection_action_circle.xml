<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_action_surface_start"
                android:endColor="@color/color_connection_action_surface_end" />
            <stroke
                android:width="1dp"
                android:color="@color/color_connection_action_stroke" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="18dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_action_highlight_top"
                android:centerColor="@color/color_connection_action_highlight_mid"
                android:endColor="@color/color_connection_action_highlight_bottom" />
        </shape>
    </item>

</layer-list>
