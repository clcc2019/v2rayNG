<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <inset
            android:insetTop="@dimen/padding_spacing_dp2"
            android:insetBottom="@dimen/padding_spacing_dp2">
            <layer-list>
                <item>
                    <shape android:shape="rectangle">
                        <solid android:color="@color/md_theme_primaryContainer" />
                        <corners android:radius="@dimen/shape_corner_dp20" />
                    </shape>
                </item>
                <item
                    android:width="3dp"
                    android:gravity="start|center_vertical">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/md_theme_primary" />
                        <corners android:radius="@dimen/shape_corner_dp20" />
                    </shape>
                </item>
            </layer-list>
        </inset>
    </item>
    <item>
        <inset
            android:insetTop="@dimen/padding_spacing_dp2"
            android:insetBottom="@dimen/padding_spacing_dp2">
            <shape android:shape="rectangle">
                <solid android:color="@android:color/transparent" />
                <corners android:radius="@dimen/shape_corner_dp20" />
            </shape>
        </inset>
    </item>
</selector>
