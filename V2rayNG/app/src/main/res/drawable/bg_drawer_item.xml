<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <inset
            android:insetTop="@dimen/padding_spacing_dp2"
            android:insetBottom="@dimen/padding_spacing_dp2">
            <layer-list>
                <item>
                    <shape android:shape="rectangle">
                        <solid android:color="@color/md_theme_surface" />
                        <stroke
                            android:width="1dp"
                            android:color="@color/color_card_outline" />
                        <corners android:radius="18dp" />
                    </shape>
                </item>
                <item
                    android:width="4dp"
                    android:gravity="start|center_vertical">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/md_theme_primary" />
                        <corners android:radius="18dp" />
                    </shape>
                </item>
            </layer-list>
        </inset>
    </item>
    <item>
        <inset
            android:insetTop="@dimen/padding_spacing_dp2"
            android:insetBottom="@dimen/padding_spacing_dp2">
            <shape android:shape="rectangle">
                <solid android:color="@color/md_theme_surface" />
                <stroke
                    android:width="1dp"
                    android:color="@color/color_card_outline" />
                <corners android:radius="18dp" />
            </shape>
        </inset>
    </item>
</selector>
