<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <gradient
                android:centerColor="@color/color_connection_backdrop_core"
                android:endColor="@color/color_connection_backdrop_edge"
                android:gradientRadius="24dp"
                android:type="radial" />
        </shape>
    </item>

    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="oval">
            <solid android:color="@color/color_connection_dock_button_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/color_connection_dock_button_stroke" />
        </shape>
    </item>

</layer-list>
