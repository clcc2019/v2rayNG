<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="1dp"
        android:top="2dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#10000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="315"
                android:endColor="#EAE6DE"
                android:startColor="#FFFDF9" />
            <stroke
                android:width="1dp"
                android:color="#DDD8D0" />
        </shape>
    </item>

    <item android:bottom="16dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#73FFFFFF" />
        </shape>
    </item>

    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <stroke
                android:width="1dp"
                android:color="#1C2785FF" />
        </shape>
    </item>
</layer-list>
