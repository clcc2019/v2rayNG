<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/shape_corner_form_field" />
            <solid android:color="@color/color_form_field_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/color_form_field_outline" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/shape_corner_form_field" />
            <solid android:color="@color/color_form_field_surface_active" />
            <stroke
                android:width="1dp"
                android:color="@color/color_form_field_outline_focus" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/shape_corner_form_field" />
            <solid android:color="@color/color_form_field_surface_active" />
            <stroke
                android:width="1dp"
                android:color="@color/color_form_field_outline_focus" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/shape_corner_form_field" />
            <solid android:color="@color/color_form_field_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/color_form_field_outline" />
        </shape>
    </item>

</selector>
