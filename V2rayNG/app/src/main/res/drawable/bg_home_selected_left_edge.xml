<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:gravity="start"
        android:width="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_home_primary" />
        </shape>
    </item>

    <item
        android:gravity="start"
        android:width="12dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#4D0580D3"
                android:centerColor="#140580D3"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
