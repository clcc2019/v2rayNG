<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:gravity="start"
        android:width="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/color_home_primary" />
        </shape>
    </item>

    <item
        android:gravity="start"
        android:width="8dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="@color/color_home_selection_glow_start"
                android:centerColor="@color/color_home_selection_glow_center"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
