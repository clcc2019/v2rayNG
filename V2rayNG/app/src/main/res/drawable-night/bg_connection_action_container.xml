<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_action_plate_top"
                android:endColor="@color/color_connection_action_plate_bottom" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="19dp" />
            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_action_plate_highlight_top"
                android:endColor="@color/color_connection_action_plate_highlight_bottom" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="12dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="19dp" />
            <gradient
                android:angle="270"
                android:startColor="@color/color_connection_action_plate_depth_top"
                android:endColor="@color/color_connection_action_plate_depth_bottom" />
        </shape>
    </item>

</layer-list>
