<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="oval">
            <solid android:color="@color/color_connection_dock_button_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/color_connection_dock_button_stroke" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:startColor="#14FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>
