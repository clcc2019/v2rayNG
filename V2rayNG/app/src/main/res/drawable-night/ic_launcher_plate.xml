<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="1dp"
        android:top="2dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#20000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="315"
                android:endColor="#192129"
                android:startColor="#2A313A" />
            <stroke
                android:width="1dp"
                android:color="#34414D" />
        </shape>
    </item>

    <item android:bottom="16dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#18FFFFFF" />
        </shape>
    </item>

    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <stroke
                android:width="1dp"
                android:color="#262785FF" />
        </shape>
    </item>
</layer-list>
