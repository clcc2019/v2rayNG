<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:text="@string/backup_group_local"
            />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_backup"
                    style="@style/Widget.V2Ray.Settings.Row">

                    <ImageView
                        style="@style/Widget.V2Ray.Settings.Icon"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_backup_24dp" />

                    <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Title"
                            android:text="@string/title_configuration_backup" />

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Subtitle"
                            android:text="@string/backup_summary_backup" />
                    </LinearLayout>
                </LinearLayout>

                <View style="@style/Widget.V2Ray.Settings.Divider" />

                <LinearLayout
                    android:id="@+id/layout_share"
                    style="@style/Widget.V2Ray.Settings.Row">

                    <ImageView
                        style="@style/Widget.V2Ray.Settings.Icon"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_share_24dp" />

                    <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Title"
                            android:text="@string/title_configuration_share" />

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Subtitle"
                            android:text="@string/backup_summary_share" />
                    </LinearLayout>
                </LinearLayout>

                <View style="@style/Widget.V2Ray.Settings.Divider" />

                <LinearLayout
                    android:id="@+id/layout_restore"
                    style="@style/Widget.V2Ray.Settings.Row">

                    <ImageView
                        style="@style/Widget.V2Ray.Settings.Icon"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_restore_24dp" />

                    <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Title"
                            android:text="@string/title_configuration_restore" />

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Subtitle"
                            android:text="@string/backup_summary_restore" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/backup_group_sync"
            />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:id="@+id/layout_webdav_config_setting"
                style="@style/Widget.V2Ray.Settings.Row">

                <ImageView
                    style="@style/Widget.V2Ray.Settings.Icon"
                    android:importantForAccessibility="no"
                    app:srcCompat="@drawable/ic_settings_24dp" />

                <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                    <TextView
                        style="@style/Widget.V2Ray.Settings.Title"
                        android:text="@string/title_webdav_config_setting" />

                    <TextView
                        style="@style/Widget.V2Ray.Settings.Subtitle"
                        android:text="@string/backup_summary_webdav" />
                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
