<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_bg"
    style="@style/Widget.V2Ray.Card.Section"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:layout_marginTop="@dimen/padding_spacing_dp6"
    android:layout_marginBottom="@dimen/padding_spacing_dp6"
    android:maxWidth="@dimen/list_card_max_width"
    android:clipToOutline="true"
    app:cardBackgroundColor="@color/color_settings_section_surface"
    app:strokeWidth="0dp">

    <LinearLayout
        android:id="@+id/info_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_settings_item_ripple"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingTop="@dimen/padding_spacing_dp16"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        android:paddingBottom="@dimen/padding_spacing_dp16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="top"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="Tokyo Premium Feed" />

                <LinearLayout
                    android:id="@+id/layout_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_url"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textAppearance="@style/TextAppearance.V2Ray.Body"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="https://example.com/subscription/tokyo" />

                </LinearLayout>

            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/chk_enable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_spacing_dp12"
                app:theme="@style/BrandedSwitch" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp12"
            android:baselineAligned="false"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_status"
                style="@style/Widget.V2Ray.Badge.SubscriptionMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Enabled" />

            <TextView
                android:id="@+id/tv_auto_update"
                style="@style/Widget.V2Ray.Badge.SubscriptionMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_spacing_dp6"
                tools:text="Auto update" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/layout_last_updated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_last_updated"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.V2Ray.Support"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="2026-03-14 14:32" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp14"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/layout_share"
                style="@style/Widget.V2Ray.Button.ListAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_configuration_share"
                app:icon="@drawable/ic_share_24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/layout_edit"
                style="@style/Widget.V2Ray.Button.ListAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_spacing_dp8"
                android:layout_weight="1"
                android:text="@string/menu_item_edit_config"
                app:icon="@drawable/ic_edit_24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/layout_remove"
                style="@style/Widget.V2Ray.Button.ListAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_spacing_dp8"
                android:layout_weight="1"
                android:text="@string/menu_item_del_config"
                app:icon="@drawable/ic_delete_24dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
