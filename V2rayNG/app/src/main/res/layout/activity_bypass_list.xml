<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp16"
    tools:context=".ui.PerAppProxyActivity">

    <TextView
        style="@style/Widget.V2Ray.PageIntro"
        android:text="@string/per_app_proxy_page_overview" />

    <TextView
        style="@style/Widget.V2Ray.SectionLabel"
        android:layout_marginTop="@dimen/padding_spacing_dp16"
        android:text="@string/title_pref_per_app_proxy" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.V2Ray.Card.Section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_spacing_dp8"
        android:maxWidth="@dimen/list_card_max_width"
        app:cardBackgroundColor="@color/color_settings_section_surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/header_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/padding_spacing_dp16"
                android:paddingTop="@dimen/padding_spacing_dp16"
                android:paddingEnd="@dimen/padding_spacing_dp16"
                android:paddingBottom="@dimen/padding_spacing_dp8"
                android:text="@string/title_pref_per_app_proxy"
                android:textAppearance="@style/TextAppearance.V2Ray.Eyebrow"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:id="@+id/container_per_app_proxy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_item_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="68dp"
                android:orientation="horizontal"
                android:paddingStart="@dimen/padding_spacing_dp16"
                android:paddingTop="@dimen/padding_spacing_dp12"
                android:paddingEnd="@dimen/padding_spacing_dp12"
                android:paddingBottom="@dimen/padding_spacing_dp12">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/per_app_proxy_settings_enable"
                    android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                    android:textColor="?attr/colorOnSurface" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_per_app_proxy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    app:theme="@style/BrandedSwitch" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="52dp"
                android:background="@color/color_card_outline" />

            <LinearLayout
                android:id="@+id/container_bypass_apps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_settings_item_ripple"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:minHeight="68dp"
                android:orientation="horizontal"
                android:paddingStart="@dimen/padding_spacing_dp16"
                android:paddingTop="@dimen/padding_spacing_dp12"
                android:paddingEnd="@dimen/padding_spacing_dp12"
                android:paddingBottom="@dimen/padding_spacing_dp12">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/switch_bypass_apps_mode"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />

                    <LinearLayout
                        android:id="@+id/layout_switch_bypass_apps_tips"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_marginStart="@dimen/padding_spacing_dp4"
                        android:clickable="true"
                        android:contentDescription="@string/switch_bypass_apps_mode"
                        android:focusable="true"
                        android:background="@drawable/bg_settings_tool_icon_ripple"
                        android:gravity="center"
                        android:padding="0dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:alpha="0.72"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_about_24dp"
                            app:tint="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_bypass_apps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    app:theme="@style/BrandedSwitch" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.V2Ray.Card.Section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/padding_spacing_dp12"
        android:layout_weight="1"
        android:maxWidth="@dimen/list_card_max_width"
        app:cardBackgroundColor="@color/color_settings_section_surface"
        app:strokeWidth="0dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="@dimen/padding_spacing_dp4"
            android:paddingBottom="@dimen/padding_spacing_dp4"
            android:scrollbars="vertical"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
