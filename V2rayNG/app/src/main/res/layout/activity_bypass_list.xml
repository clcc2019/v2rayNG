<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp16"
    tools:context=".ui.PerAppProxyActivity">

    <TextView
        style="@style/Widget.V2Ray.SectionLabel.FormPage"
        android:text="@string/title_pref_per_app_proxy" />

    <TextView
        style="@style/Widget.V2Ray.PageIntro"
        android:layout_marginTop="@dimen/padding_spacing_dp6"
        android:maxWidth="@dimen/settings_page_max_width"
        android:text="@string/per_app_proxy_page_intro" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.V2Ray.Card.Section.Flat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_spacing_dp8"
        android:maxWidth="@dimen/settings_page_max_width">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/container_per_app_proxy"
                style="@style/Widget.V2Ray.Settings.Row.CompactEnd">

                <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                    <TextView
                        style="@style/Widget.V2Ray.Settings.Title"
                        android:text="@string/per_app_proxy_settings_enable" />

                    <TextView
                        style="@style/Widget.V2Ray.Settings.Subtitle"
                        android:text="@string/per_app_proxy_enable_hint" />

                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_per_app_proxy"
                    style="@style/Widget.V2Ray.FormSwitch" />

            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:dividerColor="@color/color_card_outline"
                app:dividerInsetStart="16dp"
                app:dividerInsetEnd="16dp"
                app:dividerThickness="1dp" />

            <LinearLayout
                android:id="@+id/container_bypass_apps"
                style="@style/Widget.V2Ray.Settings.Row.CompactEnd">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Title"
                            android:text="@string/switch_bypass_apps_mode" />

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Subtitle"
                            android:text="@string/per_app_proxy_bypass_hint" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layout_switch_bypass_apps_tips"
                        style="@style/Widget.V2Ray.SectionIconButton"
                        android:layout_marginStart="@dimen/padding_spacing_dp4"
                        android:contentDescription="@string/switch_bypass_apps_mode">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:alpha="0.72"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_about_24dp"
                            app:tint="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_bypass_apps"
                    style="@style/Widget.V2Ray.FormSwitch" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        style="@style/Widget.V2Ray.SectionLabel.FormPage"
        android:layout_marginTop="@dimen/padding_spacing_dp20"
        android:text="@string/per_app_proxy_list_title" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.V2Ray.Card.Section.Flat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/padding_spacing_dp8"
        android:layout_weight="1"
        android:maxWidth="@dimen/settings_page_max_width">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/padding_spacing_dp16"
                android:paddingTop="@dimen/padding_spacing_dp16"
                android:paddingEnd="@dimen/padding_spacing_dp16"
                android:paddingBottom="@dimen/padding_spacing_dp12">

                <TextView
                    android:id="@+id/tv_selection_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                    android:textColor="?attr/colorOnSurface"
                    tools:text="已选 12 / 180 个应用" />

                <TextView
                    android:id="@+id/tv_list_summary"
                    style="@style/Widget.V2Ray.Settings.Subtitle"
                    android:layout_marginTop="@dimen/padding_spacing_dp4"
                    tools:text="常规模式下，已选应用走代理。" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp12"
                    android:clipToPadding="false"
                    android:fillViewport="false"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chip_filter_all"
                            style="@style/Widget.V2Ray.FilterChip"
                            android:text="@string/per_app_proxy_filter_all"
                            tools:selected="true" />

                        <TextView
                            android:id="@+id/chip_filter_selected"
                            style="@style/Widget.V2Ray.FilterChip"
                            android:layout_marginStart="@dimen/padding_spacing_dp6"
                            android:text="@string/per_app_proxy_filter_selected" />

                        <TextView
                            android:id="@+id/chip_filter_user"
                            style="@style/Widget.V2Ray.FilterChip"
                            android:layout_marginStart="@dimen/padding_spacing_dp6"
                            android:text="@string/per_app_proxy_filter_user" />

                        <TextView
                            android:id="@+id/chip_filter_system"
                            style="@style/Widget.V2Ray.FilterChip"
                            android:layout_marginStart="@dimen/padding_spacing_dp6"
                            android:text="@string/per_app_proxy_filter_system" />

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:dividerColor="@color/color_card_outline"
                app:dividerThickness="1dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingTop="@dimen/padding_spacing_dp2"
                    android:paddingBottom="@dimen/padding_spacing_dp2"
                    android:scrollbars="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <LinearLayout
                    android:id="@+id/layout_empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_spacing_dp24"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_empty_title"
                        style="@style/Widget.V2Ray.EmptyState.Title"
                        android:text="@string/per_app_proxy_empty_title" />

                    <TextView
                        android:id="@+id/tv_empty_subtitle"
                        style="@style/Widget.V2Ray.EmptyState.Subtitle"
                        android:layout_marginTop="@dimen/padding_spacing_dp6"
                        android:gravity="center"
                        android:text="@string/per_app_proxy_empty_subtitle" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
