<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp16"
    tools:context=".ui.UserAssetUrlActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:text="@string/sub_setting_remarks"
            />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.FormSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                style="@style/Widget.V2Ray.FormSection.Content">

                <LinearLayout
                    style="@style/Widget.V2Ray.FormGroup">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sub_setting_remarks"
                        android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                    <EditText
                        android:id="@+id/et_remarks"
                        style="@style/Widget.V2Ray.EditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_spacing_dp8"
                        android:hint="@string/sub_setting_remarks"
                        android:imeOptions="actionNext"
                        android:inputType="text|textNoSuggestions" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/title_url"
            />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.FormSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                style="@style/Widget.V2Ray.FormSection.Content">

                <LinearLayout
                    style="@style/Widget.V2Ray.FormGroup">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_url"
                        android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                    <EditText
                        android:id="@+id/et_url"
                        style="@style/Widget.V2Ray.EditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_spacing_dp8"
                        android:gravity="top|start"
                        android:hint="@string/title_url"
                        android:imeOptions="actionDone"
                        android:inputType="textUri|textMultiLine|textNoSuggestions"
                        android:maxLines="10"
                        android:minHeight="112dp"
                        android:minLines="2"
                        android:scrollbars="vertical" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
