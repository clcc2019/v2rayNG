<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tab_root"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/layout_tab_surface"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="@drawable/bg_group_tab_item_tab"
        android:baselineAligned="false"
        android:gravity="center"
        android:minHeight="@dimen/view_height_dp30"
        android:minWidth="36dp"
        android:orientation="vertical"
        android:paddingTop="1dp"
        android:paddingStart="@dimen/padding_spacing_dp4"
        android:paddingEnd="@dimen/padding_spacing_dp4"
        android:paddingBottom="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_tab_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.V2Ray.TabLarge"
                    tools:text="Default" />

                <TextView
                    android:id="@+id/tv_tab_count"
                    style="@style/Widget.V2Ray.Badge.Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_spacing_dp3"
                    android:visibility="gone"
                    tools:text="12"
                    tools:visibility="visible" />

            </LinearLayout>

            <View
                android:id="@+id/view_tab_indicator"
                android:layout_width="8dp"
                android:layout_height="2dp"
                android:layout_marginTop="1dp"
                android:background="@drawable/bg_home_selected_indicator"
                android:visibility="invisible" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
