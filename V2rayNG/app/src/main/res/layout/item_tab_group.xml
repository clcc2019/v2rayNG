<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tab_root"
    android:layout_width="wrap_content"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false">

    <LinearLayout
        android:id="@+id/layout_tab_surface"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:background="@drawable/bg_group_tab_item_tab"
        android:baselineAligned="false"
        android:gravity="center"
        android:minHeight="@dimen/view_height_dp32"
        android:minWidth="36dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/padding_spacing_dp4"
        android:paddingEnd="@dimen/padding_spacing_dp4">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="28dp">

                    <TextView
                        android:id="@+id/tv_tab_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.V2Ray.TabLarge"
                        tools:text="Default" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/et_tab_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:imeOptions="actionDone"
                        android:includeFontPadding="false"
                        android:inputType="textCapSentences"
                        android:maxLines="1"
                        android:minWidth="28dp"
                        android:padding="0dp"
                        android:textAppearance="@style/TextAppearance.V2Ray.TabLarge"
                        android:textColor="@color/color_home_on_surface"
                        android:visibility="gone"
                        tools:text="Default" />

                </FrameLayout>

                <TextView
                    android:id="@+id/tv_tab_count"
                    style="@style/Widget.V2Ray.Badge.Count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_spacing_dp3"
                    android:visibility="gone"
                    tools:text="12"
                    tools:visibility="visible" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
