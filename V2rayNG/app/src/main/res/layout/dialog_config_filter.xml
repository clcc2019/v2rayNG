<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingTop="@dimen/padding_spacing_dp10"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        android:paddingBottom="@dimen/padding_spacing_dp8">

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:text="@string/title_server"
            />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.FormSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                style="@style/Widget.V2Ray.FormSection.Content">

                <LinearLayout
                    style="@style/Widget.V2Ray.FormGroup">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_server"
                        android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                    <Spinner
                        android:id="@+id/sp_subscriptionId"
                        style="@style/Widget.V2Ray.Spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_spacing_dp8" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/server_lab_remarks"
            />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.FormSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                style="@style/Widget.V2Ray.FormSection.Content">

                <LinearLayout
                    style="@style/Widget.V2Ray.FormGroup">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/server_lab_remarks"
                        android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                    <EditText
                        android:id="@+id/et_keyword"
                        style="@style/Widget.V2Ray.EditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_spacing_dp8"
                        android:hint="@string/server_lab_remarks"
                        android:imeOptions="actionDone"
                        android:inputType="text|textNoSuggestions" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
