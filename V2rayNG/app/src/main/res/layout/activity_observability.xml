<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp20">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_spacing_dp12"
            android:maxWidth="@dimen/list_card_max_width"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:importantForAccessibility="no"
                app:srcCompat="@drawable/ic_chart_24dp"
                app:tint="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_spacing_dp10"
                android:layout_weight="1"
                android:text="@string/observability_page_overview"
                android:textAppearance="@style/TextAppearance.V2Ray.Body"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:text="@string/observability_group_metrics" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/row_metrics"
                    style="@style/Widget.V2Ray.Settings.Row.CompactEnd">

                    <ImageView
                        style="@style/Widget.V2Ray.Settings.Icon"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_ecg_24dp" />

                    <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Title"
                            android:text="@string/title_observability_metrics" />

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Subtitle"
                            android:text="@string/summary_observability_metrics" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_metrics"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:theme="@style/BrandedSwitch" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp18"
            android:text="@string/observability_group_traffic" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:id="@+id/tv_traffic_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/observability_traffic_title"
                    android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:id="@+id/tv_traffic_subtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp4"
                    android:text="@string/observability_traffic_subtitle"
                    android:textAppearance="@style/TextAppearance.V2Ray.Body"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.v2ray.ang.ui.widget.TrafficLineChartView
                    android:id="@+id/chart_traffic"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:layout_marginTop="@dimen/padding_spacing_dp12" />

                <LinearLayout
                    android:id="@+id/layout_traffic_range"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp10"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_range_1h"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="@dimen/padding_spacing_dp6"
                        android:layout_weight="1"
                        android:background="@drawable/bg_group_tab_item"
                        android:gravity="center"
                        android:text="@string/observability_range_1h"
                        android:textAppearance="@style/TextAppearance.V2Ray.Support"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/chip_range_6h"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="@dimen/padding_spacing_dp6"
                        android:layout_weight="1"
                        android:background="@drawable/bg_group_tab_item"
                        android:gravity="center"
                        android:text="@string/observability_range_6h"
                        android:textAppearance="@style/TextAppearance.V2Ray.Support"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/chip_range_24h"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="@dimen/padding_spacing_dp6"
                        android:layout_weight="1"
                        android:background="@drawable/bg_group_tab_item"
                        android:gravity="center"
                        android:text="@string/observability_range_24h"
                        android:textAppearance="@style/TextAppearance.V2Ray.Support"
                        android:textColor="?attr/colorOnSurface" />

                    <TextView
                        android:id="@+id/chip_range_7d"
                        android:layout_width="0dp"
                        android:layout_height="32dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_group_tab_item"
                        android:gravity="center"
                        android:text="@string/observability_range_7d"
                        android:textAppearance="@style/TextAppearance.V2Ray.Support"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_traffic_values"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp12"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_uplink_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/observability_uplink_label"
                        android:textAppearance="@style/TextAppearance.V2Ray.Support"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tv_uplink_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp6"
                        android:text="@string/observability_uplink_placeholder"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="@dimen/padding_spacing_dp12"
                        android:layout_marginEnd="@dimen/padding_spacing_dp12"
                        android:background="@color/color_card_outline" />

                    <TextView
                        android:id="@+id/tv_downlink_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/observability_downlink_label"
                        android:textAppearance="@style/TextAppearance.V2Ray.Support"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tv_downlink_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp6"
                        android:text="@string/observability_downlink_placeholder"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
