<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp20"
    tools:context=".ui.RoutingSettingActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            style="@style/Widget.V2Ray.PageIntro"
            android:maxWidth="@dimen/list_card_max_width"
            android:text="@string/routing_page_intro" />

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp18"
            android:text="@string/routing_group_preferences" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section.Flat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_domain_strategy"
                    style="@style/Widget.V2Ray.Settings.Row">

                    <ImageView
                        style="@style/Widget.V2Ray.Settings.Icon"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_routing_24dp" />

                    <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Title"
                            android:text="@string/routing_settings_domain_strategy" />

                        <TextView
                            android:id="@+id/tv_domain_strategy_summary"
                            style="@style/Widget.V2Ray.Settings.Subtitle"
                            android:maxLines="2"
                            />
                    </LinearLayout>
                </LinearLayout>

                <View style="@style/Widget.V2Ray.Settings.Divider" />

                <LinearLayout
                    android:id="@+id/layout_per_app_proxy_settings"
                    style="@style/Widget.V2Ray.Settings.Row">

                    <ImageView
                        style="@style/Widget.V2Ray.Settings.Icon"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_per_apps_24dp" />

                    <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Title"
                            android:text="@string/per_app_proxy_settings" />

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Subtitle"
                            android:maxLines="2"
                            android:text="@string/per_app_proxy_settings_enable"
                            />
                    </LinearLayout>
                </LinearLayout>

                <View style="@style/Widget.V2Ray.Settings.Divider" />

                <LinearLayout
                    android:id="@+id/layout_routing_assets"
                    style="@style/Widget.V2Ray.Settings.Row.CompactEnd">

                    <ImageView
                        style="@style/Widget.V2Ray.Settings.Icon"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_file_24dp" />

                    <LinearLayout style="@style/Widget.V2Ray.Settings.Content">

                        <TextView
                            style="@style/Widget.V2Ray.Settings.Title"
                            android:text="@string/title_user_asset_setting" />

                        <TextView
                            android:id="@+id/tv_routing_assets_summary"
                            style="@style/Widget.V2Ray.Settings.Subtitle"
                            android:maxLines="2"
                            android:text="@string/summary_routing_assets" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_routing_assets_updated"
                        style="@style/Widget.V2Ray.Settings.Value"
                        android:layout_marginStart="@dimen/padding_spacing_dp8"
                        android:layout_marginEnd="@dimen/padding_spacing_dp4"
                        android:ellipsize="end"
                        android:maxLines="1" />

                    <LinearLayout
                        android:id="@+id/layout_routing_assets_refresh"
                        style="@style/Widget.V2Ray.SectionIconButton"
                        android:contentDescription="@string/routing_assets_refresh">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:alpha="0.72"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_refresh_24dp"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/routing_group_rules" />

        <TextView
            android:id="@+id/tv_rule_overview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp4"
            android:maxWidth="@dimen/list_card_max_width"
            android:text="@string/routing_priority_summary"
            android:textAppearance="@style/TextAppearance.V2Ray.Body"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout_empty_state"
            style="@style/Widget.V2Ray.Card.Section.Flat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/routing_empty_title"
                    android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp4"
                    android:text="@string/routing_empty_subtitle"
                    android:textAppearance="@style/TextAppearance.V2Ray.Body"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/action_empty_add_rule"
                    style="@style/Widget.V2Ray.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp14"
                    android:text="@string/routing_settings_add_rule"
                    app:icon="@drawable/ic_add_24dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingTop="@dimen/padding_spacing_dp6"
            tools:listitem="@layout/item_recycler_routing_setting" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
