<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp20"
    tools:context=".ui.RoutingSettingActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            style="@style/Widget.V2Ray.PageIntro"
            android:text="@string/routing_page_overview" />

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/sub_group_quick_actions" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/routing_settings_title"
                    android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp4"
                    android:text="@string/routing_priority_summary"
                    android:textAppearance="@style/TextAppearance.V2Ray.Body"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/action_add_rule"
                        style="@style/Widget.V2Ray.Button.HomePrimary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/routing_settings_add_rule"
                        app:icon="@drawable/ic_add_24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/action_more_sheet"
                        style="@style/Widget.V2Ray.Button.HomeSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp10"
                        android:layout_weight="1"
                        android:text="@string/action_more"
                        app:icon="@drawable/ic_more_vert_24dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_routing_summary_panel"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_spacing_dp12">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/routing_summary_total"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tv_rule_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp8"
                        android:layout_weight="1"
                        android:background="@drawable/bg_routing_summary_panel"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_spacing_dp12">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/routing_summary_enabled"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tv_rule_enabled_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp8"
                        android:layout_weight="1"
                        android:background="@drawable/bg_routing_summary_panel"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_spacing_dp12">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/routing_summary_locked"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tv_rule_locked_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:text="0"
                            android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/routing_group_preferences" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.RoutingSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_domain_strategy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_routing_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp14"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="@dimen/padding_spacing_dp14">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.88"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_routing_24dp"
                        app:tint="?attr/colorOnSurface" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/routing_settings_domain_strategy"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tv_domain_strategy_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:maxLines="2"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="52dp"
                    android:background="@color/color_card_outline" />

                <LinearLayout
                    android:id="@+id/layout_per_app_proxy_settings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_routing_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp14"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="@dimen/padding_spacing_dp14">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.88"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_per_apps_24dp"
                        app:tint="?attr/colorOnSurface" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/per_app_proxy_settings"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:maxLines="2"
                            android:text="@string/per_app_proxy_settings_enable"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="52dp"
                    android:background="@color/color_card_outline" />

                <LinearLayout
                    android:id="@+id/layout_routing_assets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_routing_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp14"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="@dimen/padding_spacing_dp14">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.88"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_file_24dp"
                        app:tint="?attr/colorOnSurface" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/title_user_asset_setting"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tv_routing_assets_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:maxLines="2"
                            android:text="@string/summary_routing_assets"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_routing_assets_updated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp8"
                        android:layout_marginEnd="@dimen/padding_spacing_dp4"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="@style/TextAppearance.V2Ray.Support"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <LinearLayout
                        android:id="@+id/layout_routing_assets_refresh"
                        style="@style/Widget.V2Ray.SectionIconButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:contentDescription="@string/routing_assets_refresh">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:alpha="0.72"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_refresh_24dp"
                            app:tint="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/routing_group_rules" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp4"
            android:maxWidth="@dimen/list_card_max_width"
            android:text="@string/routing_priority_hint"
            android:textAppearance="@style/TextAppearance.V2Ray.Body"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layout_empty_state"
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            android:visibility="gone"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/routing_empty_title"
                    android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                    android:textColor="?attr/colorOnSurface" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp4"
                    android:text="@string/routing_empty_subtitle"
                    android:textAppearance="@style/TextAppearance.V2Ray.Body"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/action_empty_add_rule"
                    style="@style/Widget.V2Ray.Button.HomeSecondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp14"
                    android:text="@string/routing_settings_add_rule"
                    app:icon="@drawable/ic_add_24dp" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingTop="@dimen/padding_spacing_dp6"
            tools:listitem="@layout/item_recycler_routing_setting" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
