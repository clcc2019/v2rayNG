<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fitsSystemWindows="true"
    tools:context=".ui.RoutingSettingActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingTop="@dimen/padding_spacing_dp12"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        android:paddingBottom="@dimen/padding_spacing_dp16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxWidth="@dimen/list_card_max_width"
                android:text="@string/routing_page_overview"
                android:textAppearance="@style/TextAppearance.V2Ray.Body"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp16"
                android:maxWidth="@dimen/list_card_max_width"
                android:text="@string/routing_group_preferences"
                android:textAppearance="@style/TextAppearance.V2Ray.Eyebrow"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.V2Ray.Card.RoutingSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/padding_spacing_dp8"
                android:maxWidth="@dimen/list_card_max_width"
                app:cardBackgroundColor="@color/md_theme_surface"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layout_domain_strategy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="68dp"
                        android:background="@drawable/bg_routing_settings_item_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/padding_spacing_dp16"
                        android:paddingTop="@dimen/padding_spacing_dp12"
                        android:paddingEnd="@dimen/padding_spacing_dp16"
                        android:paddingBottom="@dimen/padding_spacing_dp12">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.88"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_routing_24dp"
                            app:tint="?attr/colorOnSurface" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/routing_settings_domain_strategy"
                                android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tv_domain_strategy_summary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/padding_spacing_dp4"
                                android:maxLines="1"
                                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="52dp"
                        android:background="@color/color_card_outline" />

                    <LinearLayout
                        android:id="@+id/layout_per_app_proxy_settings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="68dp"
                        android:background="@drawable/bg_routing_settings_item_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/padding_spacing_dp16"
                        android:paddingTop="@dimen/padding_spacing_dp12"
                        android:paddingEnd="@dimen/padding_spacing_dp16"
                        android:paddingBottom="@dimen/padding_spacing_dp12">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.88"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_per_apps_24dp"
                            app:tint="?attr/colorOnSurface" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/per_app_proxy_settings"
                                android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/padding_spacing_dp4"
                                android:maxLines="2"
                                android:text="@string/per_app_proxy_settings_enable"
                                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginStart="52dp"
                        android:background="@color/color_card_outline" />

                    <LinearLayout
                        android:id="@+id/layout_routing_assets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="68dp"
                        android:background="@drawable/bg_routing_settings_item_ripple"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/padding_spacing_dp16"
                        android:paddingTop="@dimen/padding_spacing_dp12"
                        android:paddingEnd="@dimen/padding_spacing_dp16"
                        android:paddingBottom="@dimen/padding_spacing_dp12">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.88"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_file_24dp"
                            app:tint="?attr/colorOnSurface" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/title_user_asset_setting"
                                android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                                android:textColor="?attr/colorOnSurface" />

                            <TextView
                                android:id="@+id/tv_routing_assets_summary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/padding_spacing_dp4"
                                android:maxLines="2"
                                android:text="@string/summary_routing_assets"
                                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                                android:textColor="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_routing_assets_updated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/padding_spacing_dp8"
                            android:layout_marginEnd="@dimen/padding_spacing_dp4"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <LinearLayout
                            android:id="@+id/layout_routing_assets_refresh"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:clickable="true"
                            android:contentDescription="@string/routing_assets_refresh"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:gravity="center"
                            android:padding="0dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:alpha="0.72"
                                android:importantForAccessibility="no"
                                app:srcCompat="@drawable/ic_refresh_24dp"
                                app:tint="?attr/colorOnSurfaceVariant" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp20"
                android:layout_marginBottom="@dimen/padding_spacing_dp4"
                android:text="@string/routing_group_rules"
                android:textAppearance="@style/TextAppearance.V2Ray.Eyebrow"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <LinearLayout
                android:id="@+id/layout_priority_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_spacing_dp8"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/routing_priority_summary"
                    android:textAppearance="@style/TextAppearance.V2Ray.Support"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_recycler_routing_setting" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>
