<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/item_bg"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_horizontal"
    android:layout_marginTop="@dimen/padding_spacing_dp4"
    android:layout_marginBottom="@dimen/padding_spacing_dp4"
    android:maxWidth="@dimen/list_card_max_width"
    android:clickable="true"
    android:focusable="true"
    android:clipToOutline="true"
    android:foreground="@drawable/bg_home_list_item_ripple"
    android:nextFocusRight="@+id/layout_more"
    app:cardBackgroundColor="@color/color_home_card_bg"
    app:strokeColor="@color/color_home_card_stroke"
    app:strokeWidth="0dp">

    <View
        android:id="@+id/view_selected_left_edge"
        android:layout_width="12dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:alpha="0"
        android:background="@drawable/bg_home_selected_left_edge"
        android:importantForAccessibility="no" />

    <LinearLayout
        android:id="@+id/info_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:gravity="top"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingTop="@dimen/padding_spacing_dp13"
        android:paddingEnd="@dimen/padding_spacing_dp14"
        android:paddingBottom="@dimen/padding_spacing_dp13">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_spacing_dp18"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:minLines="1"
                    android:paddingEnd="@dimen/padding_spacing_dp6"
                    android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                    android:textColor="@color/color_home_on_surface"
                    android:textSize="16sp"
                    tools:text="hk-aliyun fallback route" />

                <TextView
                    android:id="@+id/tv_type"
                    style="@style/Widget.V2Ray.Chip.HomeProtocolCompact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_spacing_dp8"
                    tools:text="VLESS" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_meta_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp6"
                android:orientation="vertical">

                <View
                    android:id="@+id/view_meta_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="@dimen/padding_spacing_dp4"
                    android:alpha="0.8"
                    android:background="@color/color_connection_dock_divider"
                    android:importantForAccessibility="no" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_statistics"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:minLines="1"
                        android:textAppearance="@style/TextAppearance.V2Ray.Body"
                        android:textColor="@color/color_home_on_surface_muted"
                        android:textSize="12sp"
                        android:alpha="0.9"
                        tools:text="13.213.104.*** : 443" />

                    <TextView
                        android:id="@+id/tv_test_result"
                        style="@style/Widget.V2Ray.Badge.MetricHomeCompact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp6"
                        tools:text="114ms" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_subscription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp6"
                android:background="@drawable/bg_home_secondary_panel"
                android:gravity="center_vertical"
                android:minHeight="24dp"
                android:orientation="horizontal"
                android:paddingStart="@dimen/padding_spacing_dp8"
                android:paddingTop="@dimen/padding_spacing_dp1"
                android:paddingEnd="@dimen/padding_spacing_dp8"
                android:paddingBottom="@dimen/padding_spacing_dp1"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_subscription_label"
                    style="@style/Widget.V2Ray.Badge.SubscriptionMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_server_source_label" />

                <TextView
                    android:id="@+id/tv_subscription"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_spacing_dp6"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.V2Ray.Support"
                    android:textColor="@color/color_home_on_surface_muted"
                    android:textSize="11sp"
                    android:alpha="0.96"
                    tools:text="Tokyo Premium" />

            </LinearLayout>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/layout_more"
            android:layout_width="@dimen/view_height_dp36"
            android:layout_height="@dimen/view_height_dp36"
            android:layout_marginStart="@dimen/padding_spacing_dp8"
            android:background="@drawable/bg_home_icon_circle_clear_ripple"
            android:clickable="true"
            android:contentDescription="@string/action_more"
            android:focusable="true"
            android:gravity="center"
            android:nextFocusLeft="@+id/item_bg"
            android:padding="0dp">

            <ImageView
                android:layout_width="@dimen/image_size_dp18"
                android:layout_height="@dimen/image_size_dp18"
                android:layout_gravity="center"
                android:alpha="0.82"
                app:srcCompat="@drawable/ic_more_vert_24dp"
                app:tint="@color/color_home_on_surface_muted" />

        </FrameLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
