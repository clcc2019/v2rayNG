<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/item_bg"
        style="@style/Widget.V2Ray.Card.HomeList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/padding_spacing_dp6"
        android:layout_marginBottom="@dimen/padding_spacing_dp6"
        android:maxWidth="@dimen/list_card_max_width"
        android:clipToOutline="true"
        app:cardBackgroundColor="@color/md_theme_surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:id="@+id/info_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_home_list_item_ripple"
            android:clickable="true"
            android:focusable="true"
            android:nextFocusRight="@+id/layout_more"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_spacing_dp16"
            android:paddingTop="@dimen/padding_spacing_dp14"
            android:paddingEnd="@dimen/padding_spacing_dp16"
            android:paddingBottom="@dimen/padding_spacing_dp14">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:baselineAligned="false"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:id="@+id/layout_indicator"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginTop="1dp"
                    android:layout_marginEnd="@dimen/padding_spacing_dp10"
                    android:background="@drawable/bg_item_indicator_idle" />

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:minLines="1"
                    android:paddingEnd="@dimen/padding_spacing_dp8"
                    android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    tools:text="hk-aliyun fallback route" />

                <LinearLayout
                    android:id="@+id/layout_tags"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_spacing_dp4"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_type"
                        style="@style/Widget.V2Ray.Chip.Protocol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="VLESS" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_more"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginStart="@dimen/padding_spacing_dp8"
                    android:clickable="true"
                    android:contentDescription="@string/notification_action_more"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:nextFocusLeft="@+id/info_container"
                    android:orientation="vertical"
                    android:padding="0dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.58"
                        app:srcCompat="@drawable/ic_more_vert_24dp"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp8"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_statistics"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:minLines="1"
                    android:textAppearance="@style/TextAppearance.V2Ray.Body"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:alpha="0.9"
                    tools:text="13.213.104.*** : 443" />

                <TextView
                    android:id="@+id/tv_test_result"
                    style="@style/Widget.V2Ray.Badge.Metric"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_spacing_dp10"
                    tools:text="114ms" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_subscription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp6"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_subscription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textAppearance="@style/TextAppearance.V2Ray.Support"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="11sp"
                    tools:text="Tokyo Premium" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
