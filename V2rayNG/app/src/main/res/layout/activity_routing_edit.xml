<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp16"
    tools:context=".ui.RoutingEditActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            style="@style/Widget.V2Ray.PageIntro"
            android:text="@string/routing_edit_page_overview" />

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/routing_group_rule_details" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.FormSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_setting_remarks"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <TextView
                    style="@style/Widget.V2Ray.FormFieldHint"
                    android:text="@string/routing_rule_remarks_hint" />

                <EditText
                    android:id="@+id/et_remarks"
                    style="@style/Widget.V2Ray.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/sub_setting_remarks"
                    android:inputType="textCapWords|text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:text="@string/routing_settings_outbound_tag"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <TextView
                    style="@style/Widget.V2Ray.FormFieldHint"
                    android:text="@string/routing_settings_outbound_tag_hint" />

                <Spinner
                    android:id="@+id/sp_outbound_tag"
                    style="@style/Widget.V2Ray.Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:entries="@array/outbound_tag" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:background="@color/color_card_outline" />

                <LinearLayout
                    android:id="@+id/layout_locked_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp4"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="72dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp4"
                    android:paddingTop="@dimen/padding_spacing_dp8"
                    android:paddingEnd="@dimen/padding_spacing_dp4"
                    android:paddingBottom="@dimen/padding_spacing_dp8">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingStart="@dimen/padding_spacing_dp12"
                        android:paddingEnd="@dimen/padding_spacing_dp12">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/routing_settings_locked"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:text="@string/routing_lock_rule_hint"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/chk_locked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:theme="@style/BrandedSwitch" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/routing_settings_match_conditions" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.FormSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/routing_settings_domain"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <TextView
                    style="@style/Widget.V2Ray.FormFieldHint"
                    android:text="@string/routing_settings_domain_hint" />

                <EditText
                    android:id="@+id/et_domain"
                    style="@style/Widget.V2Ray.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/routing_settings_tips"
                    android:inputType="textMultiLine"
                    android:maxLines="6"
                    android:minHeight="96dp"
                    android:minLines="2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:text="@string/routing_settings_ip"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <TextView
                    style="@style/Widget.V2Ray.FormFieldHint"
                    android:text="@string/routing_settings_ip_hint" />

                <EditText
                    android:id="@+id/et_ip"
                    style="@style/Widget.V2Ray.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/routing_settings_tips"
                    android:inputType="textMultiLine"
                    android:maxLines="6"
                    android:minHeight="96dp"
                    android:minLines="2" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:text="@string/routing_settings_port"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <TextView
                    style="@style/Widget.V2Ray.FormFieldHint"
                    android:text="@string/routing_settings_port_hint" />

                <EditText
                    android:id="@+id/et_port"
                    style="@style/Widget.V2Ray.EditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/routing_settings_port_hint"
                    android:inputType="text" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/routing_settings_advanced" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.FormSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/color_settings_section_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_advanced_toggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="64dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="@dimen/padding_spacing_dp12">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/routing_action_show_advanced"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tv_advanced_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:text="@string/routing_advanced_summary_collapsed"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/img_advanced_toggle"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_chevron_down_20dp"
                        app:tint="?attr/colorOnSurfaceVariant" />
                </LinearLayout>

                <View
                    android:id="@+id/view_advanced_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="@dimen/padding_spacing_dp16"
                    android:layout_marginEnd="@dimen/padding_spacing_dp16"
                    android:background="@color/color_card_outline"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layout_advanced_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="@dimen/padding_spacing_dp16"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/routing_settings_protocol"
                        android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                    <TextView
                        style="@style/Widget.V2Ray.FormFieldHint"
                        android:text="@string/routing_settings_protocol_help" />

                    <EditText
                        android:id="@+id/et_protocol"
                        style="@style/Widget.V2Ray.EditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_spacing_dp8"
                        android:hint="@string/routing_settings_protocol_tip"
                        android:inputType="text" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_spacing_dp12"
                        android:text="@string/routing_settings_network"
                        android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                    <TextView
                        style="@style/Widget.V2Ray.FormFieldHint"
                        android:text="@string/routing_settings_network_help" />

                    <EditText
                        android:id="@+id/et_network"
                        style="@style/Widget.V2Ray.EditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_spacing_dp8"
                        android:hint="@string/routing_settings_network_tip"
                        android:inputType="text" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
