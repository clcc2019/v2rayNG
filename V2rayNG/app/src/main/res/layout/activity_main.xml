<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_surface"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

            <androidx.coordinatorlayout.widget.CoordinatorLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false">

                <View
                    android:layout_width="248dp"
                    android:layout_height="248dp"
                    android:layout_gravity="top|end"
                    android:alpha="0.92"
                    android:background="@drawable/bg_home_glow_blue"
                    android:importantForAccessibility="no"
                    android:translationX="48dp"
                    android:translationY="-36dp" />

                <View
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:layout_gravity="top|start"
                    android:alpha="0.72"
                    android:background="@drawable/bg_home_glow_white"
                    android:importantForAccessibility="no"
                    android:translationX="-72dp"
                    android:translationY="86dp" />

                <View
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_gravity="bottom|start"
                    android:alpha="0.78"
                    android:background="@drawable/bg_home_glow_amber"
                    android:importantForAccessibility="no"
                    android:translationX="-96dp"
                    android:translationY="74dp" />

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/view_pager"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="20dp"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="96dp"
                    android:scrollbars="vertical" />

                <com.google.android.material.appbar.AppBarLayout
                    android:id="@+id/app_bar_home"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:background="@drawable/bg_home_top_bar_gradient"
                    android:elevation="0dp">

                    <com.google.android.material.appbar.MaterialToolbar
                        android:id="@+id/toolbar"
                        android:layout_width="match_parent"
                        android:layout_height="?attr/actionBarSize"
                        android:minHeight="?attr/actionBarSize"
                        android:paddingStart="@dimen/padding_spacing_dp8"
                        android:paddingTop="0dp"
                        android:paddingEnd="@dimen/padding_spacing_dp8"
                        android:paddingBottom="0dp"
                        android:background="@android:color/transparent"
                        app:subtitleTextAppearance="@style/TextAppearance.V2Ray.Support"
                        app:titleTextAppearance="@style/TextAppearance.V2Ray.ScreenTitle">

                        <FrameLayout
                            android:id="@+id/layout_group_tab_slot"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/view_height_dp40"
                            android:layout_gravity="center"
                            android:clipChildren="false"
                            android:clipToPadding="false"
                            android:visibility="gone">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/card_tab_group"
                                style="@style/Widget.V2Ray.Card.TopTabs"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/view_height_dp40"
                                android:layout_gravity="center"
                                android:alpha="1">

                                <com.google.android.material.tabs.TabLayout
                                    android:id="@+id/tab_group"
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:clipChildren="false"
                                    android:clipToPadding="false"
                                    android:minHeight="@dimen/view_height_dp40"
                                    android:background="@android:color/transparent"
                                    app:tabIndicatorAnimationMode="linear"
                                    app:tabIndicatorColor="@android:color/transparent"
                                    app:tabIndicatorFullWidth="false"
                                    app:tabIndicatorHeight="0dp"
                                    app:tabMinWidth="0dp"
                                    app:tabMode="scrollable"
                                    app:tabPaddingBottom="0dp"
                                    app:tabPaddingEnd="0dp"
                                    app:tabPaddingStart="0dp"
                                    app:tabPaddingTop="0dp"
                                    app:tabRippleColor="@android:color/transparent"
                                    app:tabSelectedTextColor="@color/color_home_on_surface"
                                    app:tabTextAppearance="@style/TabLayoutTextStyle"
                                    app:tabTextColor="@color/color_home_on_surface_muted" />

                            </com.google.android.material.card.MaterialCardView>

                        </FrameLayout>

                    </com.google.android.material.appbar.MaterialToolbar>

                </com.google.android.material.appbar.AppBarLayout>

                <View
                    android:id="@+id/view_connection_dock_underlay"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="@dimen/padding_spacing_dp16"
                    android:layout_marginEnd="@dimen/padding_spacing_dp16"
                    android:background="@drawable/bg_home_bottom_underlay_gradient"
                    android:importantForAccessibility="no" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_connection"
                    style="@style/Widget.V2Ray.Card.HomeDock"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginStart="@dimen/padding_spacing_dp16"
                    android:layout_marginEnd="@dimen/padding_spacing_dp16"
                    android:layout_marginBottom="10dp"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    app:strokeColor="@color/color_home_outline"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:gravity="center_vertical"
                        android:minHeight="60dp"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="4dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tv_connection_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_connection_title"
                                    android:textAppearance="@style/TextAppearance.V2Ray.Support"
                                    android:textColor="@color/color_home_on_surface_muted"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_connection_status"
                                    style="@style/Widget.V2Ray.Badge.ConnectionCompact"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/padding_spacing_dp8"
                                    android:text="@string/connection_not_connected_short" />

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_connection_profile"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/padding_spacing_dp6"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                                android:textColor="@color/color_home_on_surface"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/tv_connection_summary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/padding_spacing_dp2"
                                android:text="@string/home_connection_summary_short"
                                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                                android:textColor="@color/color_home_on_surface_muted"
                                android:textStyle="normal" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/layout_test"
                            style="@style/Widget.V2Ray.Button.HomeDockSecondary"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginStart="10dp"
                            android:clickable="true"
                            android:contentDescription="@string/connection_test_pending"
                            android:focusable="true"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="@null"
                            app:icon="@drawable/ic_ecg_24dp"
                            app:iconTint="@color/color_home_on_surface" />

                        <FrameLayout
                            android:id="@+id/layout_connection_surface"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="8dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <View
                                android:id="@+id/view_connection_backdrop"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_connection_soft_circle" />

                            <com.google.android.material.progressindicator.CircularProgressIndicator
                                android:id="@+id/indicator_connection_progress"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:indeterminate="true"
                                android:visibility="gone"
                                app:indicatorColor="@color/color_home_primary"
                                app:indicatorInset="0dp"
                                app:indicatorSize="48dp"
                                app:trackColor="@android:color/transparent"
                                app:trackThickness="3dp" />

                            <androidx.appcompat.widget.AppCompatImageButton
                                android:id="@+id/fab"
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_connection_action_circle"
                                android:clickable="true"
                                android:contentDescription="@string/tasker_start_service"
                                android:focusable="true"
                                android:padding="0dp"
                                android:scaleType="center"
                                android:src="@drawable/ic_play_24dp"
                                android:tint="@color/color_home_on_primary" />

                        </FrameLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </androidx.coordinatorlayout.widget.CoordinatorLayout>
    </LinearLayout>

</LinearLayout>
