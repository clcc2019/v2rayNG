<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingStart="0dp"
        android:paddingTop="0dp"
        android:paddingEnd="0dp"
        android:paddingBottom="0dp"
        android:scrollbars="vertical" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_empty_state"
        style="@style/Widget.V2Ray.Card.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginStart="@dimen/padding_spacing_dp16"
        android:layout_marginEnd="@dimen/padding_spacing_dp16"
        android:maxWidth="@dimen/list_card_max_width"
        android:visibility="gone"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_spacing_dp24"
            android:paddingTop="40dp"
            android:paddingEnd="@dimen/padding_spacing_dp24"
            android:paddingBottom="34dp">

            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_empty_state_icon"
                android:foregroundGravity="center"
                android:alpha="0.72"
                android:padding="16dp">

                <ImageView
                    android:id="@+id/iv_empty_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    app:srcCompat="@drawable/ic_subscriptions_24dp"
                    app:tint="@color/color_home_on_surface" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_empty_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp12"
                android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                android:textColor="@color/color_home_on_surface"
                android:textSize="14sp"
                android:alpha="0.94"
                tools:text="暂无配置" />

            <TextView
                android:id="@+id/tv_empty_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp6"
                android:gravity="center"
                android:maxWidth="220dp"
                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                android:textColor="@color/color_home_on_surface_muted"
                android:textSize="11sp"
                android:alpha="0.82"
                tools:text="导入或添加一个节点后，即可开始连接" />

            <LinearLayout
                android:id="@+id/layout_empty_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/action_add_connection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_home_empty_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="60dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp14"
                    android:paddingTop="@dimen/padding_spacing_dp10"
                    android:paddingEnd="@dimen/padding_spacing_dp14"
                    android:paddingBottom="@dimen/padding_spacing_dp10">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.78"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_add_24dp"
                        app:tint="@color/color_home_on_surface" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp14"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/empty_action_add_connection"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="@color/color_home_on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp2"
                            android:text="@string/empty_action_add_connection_hint"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="@color/color_home_on_surface_muted" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:alpha="0.5"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_chevron_right_20dp"
                        app:tint="@color/color_home_on_surface_muted" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/action_scan_qrcode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_home_empty_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="60dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp14"
                    android:paddingTop="@dimen/padding_spacing_dp10"
                    android:paddingEnd="@dimen/padding_spacing_dp14"
                    android:paddingBottom="@dimen/padding_spacing_dp10">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.78"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_qu_scan_24dp"
                        app:tint="@color/color_home_on_surface" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp14"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/empty_action_scan_qrcode"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="@color/color_home_on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp2"
                            android:text="@string/empty_action_scan_qrcode_hint"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="@color/color_home_on_surface_muted" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:alpha="0.5"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_chevron_right_20dp"
                        app:tint="@color/color_home_on_surface_muted" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/action_add_subscription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_home_empty_action"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="60dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp14"
                    android:paddingTop="@dimen/padding_spacing_dp10"
                    android:paddingEnd="@dimen/padding_spacing_dp14"
                    android:paddingBottom="@dimen/padding_spacing_dp10">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:alpha="0.78"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_subscriptions_24dp"
                        app:tint="@color/color_home_on_surface" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp14"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/empty_action_add_subscription"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="@color/color_home_on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp2"
                            android:text="@string/empty_action_add_subscription_hint"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="@color/color_home_on_surface_muted" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:alpha="0.5"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_chevron_right_20dp"
                        app:tint="@color/color_home_on_surface_muted" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
