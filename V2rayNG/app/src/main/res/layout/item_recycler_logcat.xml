<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.V2Ray.Card.SettingsItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/padding_spacing_dp8"
    android:layout_marginTop="@dimen/padding_spacing_dp6"
    android:layout_marginEnd="@dimen/padding_spacing_dp8"
    android:layout_marginBottom="@dimen/padding_spacing_dp6"
    app:cardBackgroundColor="@color/md_theme_surfaceVariant"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_section_action_ripple"
        android:clickable="true"
        android:focusable="true"
        android:minHeight="68dp"
        android:orientation="vertical"
        android:paddingStart="@dimen/padding_spacing_dp16"
        android:paddingTop="@dimen/padding_spacing_dp12"
        android:paddingEnd="@dimen/padding_spacing_dp16"
        android:paddingBottom="@dimen/padding_spacing_dp12">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/log_tag"
        style="@style/Widget.V2Ray.Badge.ConnectionCompact"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorOnSecondaryContainer" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/log_content"
        style="@style/Widget.V2Ray.LogContent"
        android:layout_marginTop="@dimen/padding_spacing_dp8"
        />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
