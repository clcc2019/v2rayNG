<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp16">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            style="@style/Widget.V2Ray.PageIntro"
            android:text="@string/about_page_overview"
            />

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/about_group_project"
            />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_soure_ccode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="68dp"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="@dimen/padding_spacing_dp12">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.88"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_source_code_24dp"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:text="@string/title_source_code"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="52dp"
                    android:background="@color/color_card_outline" />

                <LinearLayout
                    android:id="@+id/layout_oss_licenses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="68dp"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="@dimen/padding_spacing_dp12">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.88"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/license_24px"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:text="@string/title_oss_license"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_privacy_policy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="68dp"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp16"
                    android:paddingBottom="@dimen/padding_spacing_dp12">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.88"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_privacy_24dp"
                        app:tint="?attr/colorOnSurface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:text="@string/title_privacy_policy"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxWidth="@dimen/list_card_max_width"
            android:orientation="vertical"
            android:paddingTop="@dimen/padding_spacing_dp20"
            android:paddingBottom="@dimen/padding_spacing_dp8">

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tv_app_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                android:textColor="?attr/colorOnSurfaceVariant" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
