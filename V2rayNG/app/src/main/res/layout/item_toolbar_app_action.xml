<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbar_app_action_root"
    android:layout_width="wrap_content"
    android:layout_height="@dimen/view_size_dp40"
    android:baselineAligned="false"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackgroundBorderless"
    android:gravity="center"
    android:minHeight="@dimen/view_size_dp40"
    android:minWidth="@dimen/view_size_dp40"
    android:paddingStart="@dimen/padding_spacing_dp9"
    android:paddingEnd="@dimen/padding_spacing_dp9">

    <ImageView
        android:id="@+id/toolbar_app_icon"
        android:layout_width="@dimen/view_height_dp34"
        android:layout_height="@dimen/view_height_dp34"
        android:contentDescription="@string/bottom_nav_more"
        android:scaleType="fitCenter"
        android:src="@mipmap/ic_launcher_round" />

    <TextView
        android:id="@+id/toolbar_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_spacing_dp6"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
        android:textColor="@color/color_home_on_surface"
        android:textSize="11sp"
        android:visibility="gone" />

</LinearLayout>
