<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp20">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            style="@style/Widget.V2Ray.PageIntro"
            android:text="@string/update_page_overview" />

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/update_group_status" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_update_status"
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <FrameLayout
                        style="@style/Widget.V2Ray.Badge.IconContainer"
                        android:background="@drawable/bg_connection_badge">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            app:srcCompat="@drawable/ic_check_update_24dp"
                            app:tint="@color/md_theme_primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp12"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_status_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/update_status_ready_title"
                            android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tv_status_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:text="@string/update_status_ready_summary"
                            android:textAppearance="@style/TextAppearance.V2Ray.Body"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_status_badge"
                        style="@style/Widget.V2Ray.Badge.SubscriptionMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp10"
                        android:text="@string/update_status_badge_ready"
                        android:textColor="@color/md_theme_onPrimaryContainer" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_routing_summary_panel"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_spacing_dp12">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/update_summary_installed"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tv_current_version"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp8"
                        android:layout_weight="1"
                        android:background="@drawable/bg_routing_summary_panel"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_spacing_dp12">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/update_summary_latest"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                        <TextView
                            android:id="@+id/tv_latest_version"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:text="@string/update_summary_waiting"
                            android:textAppearance="@style/TextAppearance.V2Ray.CardTitle"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_release_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:background="@drawable/bg_routing_summary_panel"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_spacing_dp12"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/update_release_notes"
                        android:textAppearance="@style/TextAppearance.V2Ray.Support"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/tv_release_notes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_spacing_dp4"
                        android:ellipsize="end"
                        android:maxLines="6"
                        android:textAppearance="@style/TextAppearance.V2Ray.Body"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp16"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/action_check_update"
                        style="@style/Widget.V2Ray.Button.HomePrimary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/update_action_check_now"
                        app:icon="@drawable/ic_check_update_24dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/action_view_update"
                        style="@style/Widget.V2Ray.Button.HomeSecondary"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp10"
                        android:layout_weight="1"
                        android:text="@string/update_action_view_details"
                        android:visibility="gone"
                        app:icon="@drawable/ic_description_24dp" />
                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            style="@style/Widget.V2Ray.SectionLabel"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/update_group_preferences" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            android:maxWidth="@dimen/list_card_max_width"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/layout_pre_release"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:minHeight="68dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp12"
                    android:paddingBottom="@dimen/padding_spacing_dp12">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:alpha="0.88"
                        android:importantForAccessibility="no"
                        app:srcCompat="@drawable/ic_source_code_24dp"
                        app:tint="?attr/colorOnSurface" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_spacing_dp14"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/update_check_pre_release"
                            android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_spacing_dp4"
                            android:text="@string/update_pre_release_summary"
                            android:textAppearance="@style/TextAppearance.V2Ray.Support"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/check_pre_release"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:theme="@style/BrandedSwitch" />
                </LinearLayout>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:maxWidth="@dimen/list_card_max_width"
            android:orientation="vertical"
            android:paddingTop="@dimen/padding_spacing_dp20"
            android:paddingBottom="@dimen/padding_spacing_dp8">

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                android:textColor="?attr/colorOnSurfaceVariant" />

            <TextView
                android:id="@+id/tv_last_checked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>
