<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/settings_item_surface"
        style="@style/Widget.V2Ray.Card.SettingsItem"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToOutline="true"
        android:duplicateParentState="true"
        app:cardBackgroundColor="@color/color_settings_row_surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/settings_row_container"
                style="@style/Widget.V2Ray.Settings.Row"
                android:background="?attr/selectableItemBackground"
                android:clickable="false"
                android:duplicateParentState="true"
                android:focusable="false">

                <LinearLayout
                    android:id="@android:id/icon_frame"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="@dimen/padding_spacing_dp14"
                    android:gravity="center"
                    android:visibility="gone">

                    <ImageView
                        android:id="@android:id/icon"
                        style="@style/Widget.V2Ray.Settings.Icon"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    style="@style/Widget.V2Ray.Settings.Content">

                    <TextView
                        android:id="@android:id/title"
                        style="@style/Widget.V2Ray.Settings.Title" />

                    <TextView
                        android:id="@android:id/summary"
                        style="@style/Widget.V2Ray.Settings.Subtitle"
                        android:maxLines="4" />

                </LinearLayout>

                <LinearLayout
                    android:id="@android:id/widget_frame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/padding_spacing_dp12"
                    android:gravity="center_vertical"
                    android:minHeight="@dimen/view_height_dp36"
                    android:orientation="horizontal" />

            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:id="@+id/settings_row_divider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:dividerColor="@color/color_card_outline"
                app:dividerInsetStart="54dp"
                app:dividerThickness="1dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
