<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center_horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/padding_spacing_dp4"
    android:layout_marginBottom="@dimen/padding_spacing_dp4"
    android:maxWidth="@dimen/list_card_max_width"
    style="@style/Widget.V2Ray.Card.SettingsItem">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_settings_item_ripple"
        android:gravity="center_vertical"
        android:minHeight="@dimen/view_height_dp64"
        android:orientation="horizontal"
        android:paddingStart="@dimen/padding_spacing_dp18"
        android:paddingTop="@dimen/padding_spacing_dp12"
        android:paddingEnd="@dimen/padding_spacing_dp18"
        android:paddingBottom="@dimen/padding_spacing_dp12">

        <LinearLayout
            android:id="@android:id/icon_frame"
            android:layout_width="@dimen/view_size_dp36"
            android:layout_height="@dimen/view_size_dp36"
            android:layout_marginEnd="@dimen/padding_spacing_dp14"
            android:background="@drawable/bg_settings_icon_container"
            android:gravity="center"
            android:visibility="gone">

            <ImageView
                android:id="@android:id/icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:alpha="0.82"
                android:tint="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@android:id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@android:id/summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_spacing_dp4"
                android:maxLines="4"
                android:textAppearance="@style/TextAppearance.V2Ray.Support"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <LinearLayout
            android:id="@android:id/widget_frame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_spacing_dp12"
            android:minHeight="@dimen/view_height_dp36"
            android:gravity="center_vertical"
            android:orientation="horizontal" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
