<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp10"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp8">

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.V2Ray.Card.FormSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxWidth="@dimen/list_card_max_width"
        app:strokeWidth="0dp">

        <LinearLayout
            style="@style/Widget.V2Ray.FormSection.Content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                style="@style/Widget.V2Ray.FormGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_webdav_url"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_webdav_url"
                    style="@style/Widget.V2Ray.EditText.BottomSheet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/title_webdav_url"
                    android:imeOptions="actionNext"
                    android:inputType="textUri|textNoSuggestions" />
            </LinearLayout>

            <LinearLayout
                style="@style/Widget.V2Ray.FormGroup.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_webdav_user"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_webdav_user"
                    style="@style/Widget.V2Ray.EditText.BottomSheet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/title_webdav_user"
                    android:imeOptions="actionNext"
                    android:inputType="text|textNoSuggestions" />
            </LinearLayout>

            <LinearLayout
                style="@style/Widget.V2Ray.FormGroup.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_webdav_pass"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_webdav_pass"
                    style="@style/Widget.V2Ray.EditText.BottomSheet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/title_webdav_pass"
                    android:imeOptions="actionNext"
                    android:inputType="textPassword" />
            </LinearLayout>

            <LinearLayout
                style="@style/Widget.V2Ray.FormGroup.Compact"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_webdav_remote_path"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_webdav_remote_path"
                    style="@style/Widget.V2Ray.EditText.BottomSheet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/title_webdav_remote_path"
                    android:imeOptions="actionDone"
                    android:inputType="text|textNoSuggestions" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
