<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/toolbar_action_hub_button"
    android:layout_width="@dimen/view_height_dp36"
    android:layout_height="@dimen/view_height_dp36"
    android:background="@drawable/bg_home_icon_circle_ripple"
    android:clickable="true"
    android:focusable="true"
    android:padding="0dp">

    <ImageView
        android:id="@+id/toolbar_action_hub_icon"
        android:layout_width="@dimen/image_size_dp22"
        android:layout_height="@dimen/image_size_dp22"
        android:layout_gravity="center"
        android:contentDescription="@null"
        android:src="@drawable/ic_more_vert_24dp"
        android:tint="@color/color_home_on_surface" />

</FrameLayout>
