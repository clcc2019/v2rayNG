<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true"
    android:paddingStart="@dimen/padding_spacing_dp16"
    android:paddingTop="@dimen/padding_spacing_dp12"
    android:paddingEnd="@dimen/padding_spacing_dp16"
    android:paddingBottom="@dimen/padding_spacing_dp16"
    tools:context=".ui.SubEditActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_sub_setting"
            android:textAppearance="@style/TextAppearance.V2Ray.Body"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp16"
            android:text="@string/title_sub_setting"
            android:textAppearance="@style/TextAppearance.V2Ray.Eyebrow"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_setting_remarks"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_remarks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:inputType="text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp12"
                    android:text="@string/sub_setting_url"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:maxLines="10"
                    android:minLines="2"
                    android:scrollbars="vertical"
                    tools:ignore="TextFields" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp12"
                    android:text="@string/sub_setting_user_agent"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_user_agent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:inputType="text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp12"
                    android:text="@string/sub_setting_filter"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_filter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:inputType="text" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/title_settings"
            android:textAppearance="@style/TextAppearance.V2Ray.Eyebrow"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:gravity="center_vertical"
                    android:minHeight="68dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp12"
                    android:paddingBottom="@dimen/padding_spacing_dp12">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sub_setting_enable"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/chk_enable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:theme="@style/BrandedSwitch" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="52dp"
                    android:background="@color/color_card_outline" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:gravity="center_vertical"
                    android:minHeight="68dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp12"
                    android:paddingBottom="@dimen/padding_spacing_dp12">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sub_auto_update"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/auto_update_check"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:theme="@style/BrandedSwitch" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="52dp"
                    android:background="@color/color_card_outline" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_settings_item_ripple"
                    android:gravity="center_vertical"
                    android:minHeight="68dp"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_spacing_dp16"
                    android:paddingTop="@dimen/padding_spacing_dp12"
                    android:paddingEnd="@dimen/padding_spacing_dp12"
                    android:paddingBottom="@dimen/padding_spacing_dp12">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/sub_allow_insecure_url"
                        android:textAppearance="@style/TextAppearance.V2Ray.BodyStrong"
                        android:textColor="?attr/colorOnSurface" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/allow_insecure_url"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:theme="@style/BrandedSwitch" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp20"
            android:text="@string/sub_setting_pre_profile"
            android:textAppearance="@style/TextAppearance.V2Ray.Eyebrow"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.V2Ray.Card.Section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_spacing_dp8"
            app:cardBackgroundColor="@color/md_theme_surface"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_spacing_dp16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_setting_pre_profile"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_pre_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/sub_setting_pre_profile_tip"
                    android:inputType="text" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp12"
                    android:text="@string/sub_setting_next_profile"
                    android:textAppearance="@style/TextAppearance.V2Ray.FormLabel" />

                <EditText
                    android:id="@+id/et_next_profile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_spacing_dp8"
                    android:hint="@string/sub_setting_pre_profile_tip"
                    android:inputType="text" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
